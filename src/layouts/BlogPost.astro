---
import Layout from "./Layout.astro";
const { frontmatter } = Astro.props;
const dateLabel = new Date(frontmatter.pubDate).toLocaleDateString('en-US', {
  timeZone: 'UTC', month: 'short', day: 'numeric', year: 'numeric',
});
---
<Layout title={frontmatter.title}>
  <div class="max-w-4xl mx-auto px-6 sm:px-14 pt-[72px] pb-16">
    <div class="flex items-center gap-2.5 mb-[22px] text-[12px] text-ink-soft font-medium tracking-[0.04em] uppercase tabular-nums">
      <span class="w-1.5 h-1.5 rounded-full bg-accent shrink-0"></span>
      <span>{dateLabel}</span>
    </div>
    <h1 class="font-bold text-[32px] leading-[1.15] tracking-[-0.025em] mt-0 mb-9">
      {frontmatter.title}
    </h1>
    <div class="prose max-w-none text-[16.5px] leading-[1.7] text-ink">
      <slot />
    </div>

    {frontmatter.syndication && frontmatter.syndication.length > 0 && (
      <div class="text-ink-soft text-[13px] mt-6">
        Syndicated to:{' '}
        {frontmatter.syndication.map((link: { name: string; url: string }, index: number) => (
          <span>
            {index > 0 && ' | '}
            <a href={link.url} class="text-ink-soft underline underline-offset-2 hover:text-ink">{link.name}</a>
          </span>
        ))}
      </div>
    )}

    {frontmatter.tags && frontmatter.tags.length > 0 && (
      <div class="mt-3">
        <ul class="flex flex-wrap gap-3 list-none p-0 m-0">
          {frontmatter.tags.map((tag: string) => (
            <li>
              <a href={`/tags/${tag}/`} class="text-ink-soft text-[13px] no-underline hover:text-ink transition-colors">
                #{tag}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="mt-9 pt-5 border-t border-rule text-[13px] text-ink-soft">
      ← <a href="/" class="text-ink-soft no-underline hover:text-ink transition-colors">Back to all posts</a>
    </div>
  </div>
</Layout>
