---
import "../styles/global.css";

const { title } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-white text-ink min-h-screen flex flex-col font-sans">
    <header class="border-b border-rule shrink-0">
      <div
        class="max-w-4xl mx-auto px-6 sm:px-14 py-7 flex items-center justify-between"
      >
        <a href="/" class="flex items-center gap-2.5 text-ink no-underline">
          <span class="w-[7px] h-[7px] rounded-full bg-accent shrink-0"></span>
          <span class="font-bold text-lg tracking-[-0.005em]"
            >short thoughts</span
          >
        </a>
        <nav class="flex items-center gap-5 sm:gap-7">
          <a href="/" class="text-sm font-medium pb-1.5">Home</a>
          <a href="/archive" class="text-sm font-medium pb-1.5">Archive</a>
          <a href="/tags" class="text-sm font-medium pb-1.5">Tags</a>
          <a href="/rss.xml" class="text-sm font-medium pb-1.5">RSS</a>
        </nav>
      </div>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <footer>
      <div class="pr-6 text-xs text-ink-softer text-right">
        <span>© {year} Christopher Lopes</span>
      </div>
    </footer>
  </body>
</html>
